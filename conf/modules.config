process {
    withLabel: mafft {
        container = "dlejeune/mafft:7.525"
        cpus = { 16 }
        memory = { 32.GB }
        time = { 24.h }
    }

    withName: MAFFT {
        ext.args = params.mafft_args
    }

    withName: MAFFT_SEED {
        ext.args = params.mafft_args
    }

    withName: MAFFT_FAST_ALIGN {
        ext.args = params.mafft_fast_align_args
    }

    withName: AGA {
        container = "dlejeune/aga:0.2.1"
        cpus = { 16 }
        memory = { 32.GB }
        time = { 4.h }
        ext.args = params.aga_args
    }

    withName: MINIMAP_TWO {
        container = "dlejeune/minimap2:2.30"
        cpus = { 8 }
        memory = { 8.GB }
        time = { 1.h }
        ext.args = null
    }

    withLabel: muscle {
        container = "dlejeune/muscle:5.1.0"
        cpus = { 16 }
        memory = { 32.GB }
        time = { 24.h }
    }

    withLabel: pipeline_utils_rs {
        container = "dlejeune/pipeline-utils-rs:4.3.0"
        cpus = 2
        memory = '1 GB'
        time = '10m'
    }

    withName: FILTER_LENGTH {
        ext.args = {
            def center_args
            if (params.lbf_threshold_mode == "FIXED") {
                if (params.lbf_min_length == null) {
                    throw new IllegalArgumentException("lbf_min_length must be set when lbf_threshold_mode is FIXED.")
                }
                center_args = "--length ${params.lbf_min_length}"
            }
            else if (params.lbf_threshold_mode == "MEDIAN") {
                center_args = "--median"
            }
            else if (params.lbf_threshold_mode == "MEAN") {
                center_args = "--mean"
            }
            else {
                throw new IllegalArgumentException("Unrecognized lbf_threshold_mode: ${params.lbf_threshold_mode}")
            }

            if (params.lbf_tolerance != null && (params.lbf_min_tolerance != null || params.lbf_max_tolerance != null)) {
                throw new IllegalArgumentException("lbf_tolerance cannot be combined with lbf_min_tolerance/lbf_max_tolerance.")
            }

            def tolerance_args = ""
            if (params.lbf_tolerance != null) {
                tolerance_args += " --tolerance ${params.lbf_tolerance}"
            }
            if (params.lbf_min_tolerance != null) {
                tolerance_args += " --min-tolerance ${params.lbf_min_tolerance}"
            }
            if (params.lbf_max_tolerance != null) {
                tolerance_args += " --max-tolerance ${params.lbf_max_tolerance}"
            }

            return center_args + tolerance_args
        }.call()
    }

    withName: FUNCTIONAL_FILTER {
        container = "dlejeune/functional-filter:0.2.8"
        cpus = 2
        memory = '8 GB'
        time = '10 m'
        ext.args = "--max-stop-pct ${params.ff_max_stop_pct} \
        --acceptable-pct-loss ${params.ff_acceptable_pct_loss} \
        ${params.ff_expected_length ? '--expected-length' + params.ff_expected_length : ''} \
        ${params.ff_include_frameshifts ? '--include-frameshifts' : '--no-include-frameshifts'} \
        ${params.ff_include_no_stop_codons ? '--include-no-stop-codons' : '--no-include-no-stop-codons'}"
    }

    withName: IQTREE {
        container = "dlejeune/iqtree:2.0.7"
        ext.args = params.iqtree_args
    }

    withName: MINDIST {
        container = "ubuntu:22.04"
    }

    withName: PROBCONS {
        container = "dlejeune/probcons:1.12"
        cpus = { 8 }
        memory = { 16.GB }
        time = { 24.h }
    }

    withName: TCOFFEE {
        container = "dlejeune/tcoffee:13.46.0"
        memory = { 16.GB }
        cpus = { 16 }
        time = { 24.h }
        ext.args = params.tcoffee_args
    }

    withName: REGRESSIVE_TCOFFEE {
        container = "dlejeune/tcoffee:13.46.0"
        memory = { 16.GB }
        time = { 24.h }
        cpus = { 16 }
        ext.args = params.tcoffee_regressive_args
    }

    withName: PRANK {
        container = "dlejeune/prank:250331"
        memory = { 16.GB }
        time = { 24.h }
        ext.args = params.prank_args
    }

    withName: PAGAN {
        container = "dlejeune/pagan:20190829"
        memory = { 16.GB }
        time = { 4.h }
        cpus = { 8 }
        ext.args = params.pagan_args
    }

    withName: CLUSTAL_OMEGA {
        container = "biocontainers/clustal-omega:v1.2.1_cv5"
        memory = { 16.GB }
        time = { 24.h }
        cpus = { 16 }
        ext.args = params.clustalo_args
    }

    withName: CLUSTALW {
        container = "dlejeune/clustalw:2.1"
        memory = { 16.GB }
        time = { 24.h }
        cpus = { 16 }
        ext.args = params.clustalw_args
    }

    withName: VIRULIGN {
        ext.args = params.virulign_args
    }

    withName: MACSE {
        ext.args = params.macse_args
    }

    withLabel: codonAligner {
        container = "dlejeune/codon-aware-aligners:1.0.0"
        memory = { 16.GB }
        time = { 24.h }
        cpus = { 16 }
    }

    withName: PIPELINE_REPORT {
        container = "dlejeune/pipeline-report:1.1.0"
        memory = { 8.GB }
        time = { 1.h }
        cpus = { 8 }
    }
}
